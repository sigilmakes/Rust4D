// Rust4D Shape Gallery
//
// Demonstrates the engine's full primitive catalog: tesseract, the four
// regular polytopes implemented by the primitive library (5-cell, 16-cell,
// 24-cell, 600-cell), and the curved 4D shapes (hypersphere, spherinder,
// cubinder, duocylinder). The hypersphere is dynamic to verify collider
// creation; the rest are static visual exhibits.
Scene(
    name: "Shape Gallery",
    entities: [
        EntityTemplate(
            name: Some("floor"),
            tags: ["static"],
            transform: Transform4D(
                position: Vec4(x: 0.0, y: -2.0, z: 0.0, w: 0.0),
                rotation: (s: 1.0, b_xy: 0.0, b_xz: 0.0, b_xw: 0.0, b_yz: 0.0, b_yw: 0.0, b_zw: 0.0, p: 0.0),
                scale: 1.0,
            ),
            shape: ShapeTemplate(
                type: "Hyperplane",
                y: -2.0,
                size: 22.0,
                subdivisions: 22,
                cell_size: 8.0,
                thickness: 0.001,
            ),
            material: Material(base_color: (0.36, 0.36, 0.40, 1.0)),
        ),
        EntityTemplate(
            name: Some("tesseract"),
